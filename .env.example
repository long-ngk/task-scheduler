# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=task_scheduler

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Scheduler
SCHEDULER_POLL_INTERVAL_MS=1000
SCHEDULER_MAX_TOLERANCE_MS=5000

# Task defaults
TASK_DEFAULT_TIMEOUT_SECONDS=30
TASK_DEFAULT_MAX_RETRIES=3
TASK_RETRY_BASE_DELAY_SECONDS=1
TASK_RETRY_MULTIPLIER=2
TASK_RETRY_MAX_DELAY_SECONDS=300

# File system
FILESYSTEM_ALLOWED_BASE_PATHS=/data
FILESYSTEM_MAX_FILE_SIZE_BYTES=10485760

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Queue
QUEUE_MAX_PAYLOAD_SIZE_BYTES=1048576
