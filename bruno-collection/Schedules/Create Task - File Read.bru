meta {
  name: Create Task - File Read
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/schedules
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "type": "file_read",
    "payload": {
      "filePath": "/data/sample.txt"
    },
    "scheduleAt": "2026-06-16T10:00:00.000Z"
  }
}
